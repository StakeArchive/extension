# Copy to .env.local for builds. These are all PUBLIC, browser-safe values.
# NEVER put LICENSE_PRIVATE_KEY here — that lives only in Supabase secrets.

# Ed25519 public key (hex) that matches LICENSE_PRIVATE_KEY on the server.
# Generate a pair with: node scripts/gen-license-key.mjs
VITE_LICENSE_PUBLIC_KEY=

# Online license check / heartbeat endpoint (Supabase edge function).
VITE_VERIFY_ENDPOINT=https://YOUR-PROJECT.supabase.co/functions/v1/verify-license

# Where "Get Pro" sends users from inside the extension.
VITE_PRICING_URL=https://stakearchive.app/pricing

# Where the Account panel's "account dashboard" link sends users for their key.
VITE_DASHBOARD_URL=https://stakearchive.app/dashboard

# Discord invite the concurrent-use warning links to. Replace with your real invite.
VITE_DISCORD_URL=https://discord.com/invite/zHnFrYaF2w
